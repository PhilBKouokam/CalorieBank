# ==================== CalorieBank V0.1 ====================

# MongoDB Atlas - Replace with your own
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/caloriebank?retryWrites=true&w=majority

# JWT Secret - Change this to a long random string
JWT_SECRET=your_super_long_random_secret_key_here_2026_caloriebank_make_it_very_long

# AWS S3 (for food photos) - Replace with your real keys
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here_for_example_only

# Safe to keep as real values
AWS_REGION=us-east-1
# Optional aliases also supported:
# AWS_DEFAULT_REGION=us-east-1
# S3_REGION=us-east-1
AWS_BUCKET_NAME=caloriebank-food-photos-2026-phil

# Server
PORT=4700
NODE_ENV=development

# ==================== CalorieBank V0.1 ====================

# MongoDB Atlas - Replace with your own
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# JWT Secret - Change this to a long random string
JWT_SECRET=<jwt-secret>

# AWS S3 (for food photos) - Replace with your real keys
AWS_ACCESS_KEY_ID=replace-with-your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-aws-secret-access-key

# Safe to keep as real values
AWS_REGION=us-east-1
# Optional aliases also supported:
# AWS_DEFAULT_REGION=us-east-1
# S3_REGION=us-east-1
AWS_BUCKET_NAME=replace-with-your-s3-bucket-name

# Server
PORT=4700
NODE_ENV=development

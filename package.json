{
  "name": "caloriebank",
  "version": "0.1.0",
  "private": true,
  "description": "CalorieBank mobile V1 monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm --workspace @caloriebank/api run dev",
    "api:build": "npm --workspace @caloriebank/api run build",
    "api:start": "npm --workspace @caloriebank/api run start",
    "db:generate": "npm --workspace @caloriebank/api run db:generate",
    "db:migrate": "npm --workspace @caloriebank/api run db:migrate",
    "db:deploy": "npm --workspace @caloriebank/api run db:deploy",
    "bank:seed": "npm --workspace @caloriebank/api run seed:bank-history",
    "bank:orchestrate": "npm --workspace @caloriebank/api run orchestrate:finalization --",
    "mobile:start": "npm --workspace @caloriebank/mobile run start --",
    "mobile:ios": "npm --workspace @caloriebank/mobile run ios --",
    "mobile:ios:device": "npm --workspace @caloriebank/mobile run ios:device --",
    "mobile:prebuild:ios": "npm --workspace @caloriebank/mobile run prebuild:ios --",
    "mobile:android": "npm --workspace @caloriebank/mobile run android --",
    "mobile:web": "npm --workspace @caloriebank/mobile run web --",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "test": "npm --workspaces --if-present run test"
  },
  "engines": {
    "node": ">=20.19.0 <21"
  }
}

{
  "name": "@caloriebank/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "predev": "npm --workspace @caloriebank/domain run build && npm --workspace @caloriebank/schemas run build",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm --workspace @caloriebank/domain run build && npm --workspace @caloriebank/schemas run build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "seed:bank-history": "tsx src/scripts/seed-bank-history.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "pretypecheck": "npm --workspace @caloriebank/domain run build && npm --workspace @caloriebank/schemas run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "npm --workspace @caloriebank/domain run build && npm --workspace @caloriebank/schemas run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@caloriebank/domain": "*",
    "@caloriebank/schemas": "*",
    "@prisma/client": "6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "prisma": "6.19.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
